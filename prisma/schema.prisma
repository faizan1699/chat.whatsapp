generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model DeletedMessage {
  id                String   @id @default(cuid())
  originalMessageId String
  conversationId    String
  senderId          String
  deletedBy         String
  originalContent   String
  originalAudioUrl  String?
  originalAudioDuration Float?
  timestamp         DateTime @default(now())
  deletionReason    String   @default("deleted_by_sender")
  replyTo           Json?
  isVoiceMessage    Boolean  @default(false)
  isEdited          Boolean  @default(false)
  isPinned          Boolean  @default(false)
  
  conversation      Conversation @relation(fields: [conversationId], references: [id])
  sender            User         @relation(fields: [senderId], references: [id])
  deletedByUser     User         @relation("DeletedByUser", fields: [deletedBy], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([deletedBy])
  @@index([originalMessageId])
}

model User {
  id               String         @id @default(cuid())
  username         String         @unique
  email            String?        @unique
  phoneNumber      String?        @unique
  password         String
  avatar           String?
  lastSeen         DateTime       @default(now())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  
  // Legal and consent fields
  termsAccepted    Boolean        @default(false)
  termsAcceptedAt  DateTime?
  cookieConsent    Json?          // Store cookie preferences as JSON
  cookieConsentAt  DateTime?
  
  // User meta information
  userMeta         UserMeta?
  
  // Conversations where this user is a participant
  conversations    ConversationParticipant[]
  
  // Messages sent by this user
  messages         Message[]
  
  // Messages deleted by this user
  deletedMessages  DeletedMessage[] @relation("DeletedByUser")
  
  // Messages this user sent that were deleted
  sentDeletedMessages DeletedMessage[]
}

model UserMeta {
  id           String    @id @default(cuid())
  userId       String    @unique
  bio          String?   @default("")
  dateOfBirth  DateTime?
  fatherName   String?
  address      String?
  cnic         String?   @unique
  gender       String?   // 'male', 'female', 'other'
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userHobbies  UserHobby[]
}

model Hobby {
  id        String      @id @default(cuid())
  name      String      @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  
  userHobbies UserHobby[]
}

model UserHobby {
  id        String   @id @default(cuid())
  userId    String
  hobbyId   String
  createdAt DateTime @default(now())
  
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  
  @@unique([userId, hobbyId])
  @@index([userId])
  @@index([hobbyId])
}

model Conversation {
  id        String   @id @default(cuid())
  name      String?  // Optional for group names, null for 1-on-1
  isGroup   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
  deletedMessages DeletedMessage[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  userId         String
  conversationId String
  user           User         @relation(fields: [userId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  joinedAt       DateTime     @default(now())

  @@unique([userId, conversationId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String?  @default("")
  timestamp      DateTime @default(now())
  status         String   @default("sent") // pending, sent, delivered, read
  isVoiceMessage Boolean  @default(false)
  audioUrl       String?
  audioDuration  Float?
  isEdited       Boolean  @default(false)
  isDeleted      Boolean  @default(false)
  isPinned       Boolean  @default(false)
  deletedBy      String?  // User ID who deleted the message for everyone
  isDeletedFromMe Json?    @default("[]") // Array of user IDs who hid the message for themselves
  isHidden       Boolean  @default(false) // When true, message is hidden from everyone
  hideFromAll    Boolean  @default(false) // When true, message is hidden from everyone
  replyTo        Json?    // Store partial message for reply
  groupId        String?  // For chunked messages (UI level)
  chunkIndex     Int?
  totalChunks    Int?
  
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([hideFromAll])
  @@index([isHidden])
}
